# Copie este arquivo para .env no projeto do site da Delegacia Eletrônica.
# O site precisa enviar discordId + numero do boletim para o bot.

BOT_API_URL=https://bot-de-funcional.onrender.com/boletim
BOT_API_TOKEN=troque_por_um_token_secreto_igual_ao_do_render

# Nome dos campos que o site deve coletar/salvar:
# discordId = ID do Discord da pessoa que abriu o boletim
# numero = número do boletim gerado pelo site
