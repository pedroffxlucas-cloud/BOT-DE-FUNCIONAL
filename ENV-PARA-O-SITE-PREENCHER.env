# ENV PARA O SITE DA DELEGACIA ELETRONICA
# Seu amigo deve copiar este arquivo para o projeto do site e renomear para .env

# URL da API do bot no Render
BOT_API_URL=https://bot-de-funcional.onrender.com/boletim

# Crie uma senha/token secreto e coloque o mesmo valor aqui e no Render do bot.
# Exemplo: pc_guarulhos_2026_token_grande
BOT_API_TOKEN=COLOQUE_AQUI_O_MESMO_TOKEN_DO_RENDER

# O site precisa enviar estes dois dados para o bot:
# discordId = ID do Discord da pessoa que abriu o boletim
# numero = numero do boletim gerado pelo site
